# Agent Configuration
AGENT_TYPE=molmoweb  # "molmoweb" or "gemini"

# MolmoWeb prompt tag (must be molmo_web_think for this codebase)
STYLE=molmo_web_think

# ---------------------------------------------------------------------------
# MolmoWeb inference (only when AGENT_TYPE=molmoweb)
# ---------------------------------------------------------------------------
# INFERENCE_MODE must be exactly "modal" or "fastapi". Only the variables for
# the active mode are used; the other URL vars are ignored.
#
# --- MODAL (hosted Modal HTTPS endpoint) ---
#   Set:  INFERENCE_MODE=modal
#   Set:  MODAL_ENDPOINT=<your Modal app URL>   (full URL to your completion handler)
#   Set:  MODAL_API_KEY=... only if that endpoint requires Authorization: Bearer ...
#   You do not need FASTAPI_ENDPOINT in this mode.
#
# --- FASTAPI (your own inference server) ---
#   Set:  INFERENCE_MODE=fastapi
#   Set:  FASTAPI_ENDPOINT=<base URL only>     (no trailing /predict; the client adds /predict)
#   The API container must reach this host: e.g. http://host.docker.internal:8001 on Docker Desktop
#   You do not need MODAL_ENDPOINT / MODAL_API_KEY in this mode (leave blank).
# ---------------------------------------------------------------------------
INFERENCE_MODE=modal

MODAL_ENDPOINT=
MODAL_API_KEY=

FASTAPI_ENDPOINT=

# Gemini Agent Settings (used when AGENT_TYPE=gemini)
GEMINI_MODEL=gemini-2.5-computer-use-preview-10-2025
GOOGLE_API_KEY=

# BrowserBase
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Database (docker-compose overrides POSTGRES_URL for the API; bundled DB name is web-olmo-demo, host port 5433)
POSTGRES_URL=postgres://foo:bar@localhost:5433/web-olmo-demo

# Debug
DEBUG=true
